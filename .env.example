# -----------------------------------------------
# NexusGrid — copy to .env and fill in your values
# cp .env.example .env
# -----------------------------------------------

# --- Auth Service ---
# Internal cluster URL (pod-to-pod, do not change for local dev)
KEYCLOAK_INTERNAL_URL=http://keycloak:8080
# Public URL reachable by the browser (via skaffold port-forward)
KEYCLOAK_PUBLIC_URL=http://localhost:8180
KEYCLOAK_REALM=nexusgrid
KEYCLOAK_CLIENT_ID=nexusgrid-client
KEYCLOAK_CLIENT_SECRET=change-me-in-production
# URL Keycloak redirects back to after login
REDIRECT_URL=http://localhost:8081/callback
# Where to send the user after successful login
FRONTEND_URL=http://localhost:3000

# --- API Gateway ---
AUTH_SERVICE_URL=http://auth-service
ALLOWED_ORIGIN=http://localhost:3000

# --- Frontend ---
API_GATEWAY_URL=http://api-gateway
# AUTH_SERVICE_URL same as above, used in Next.js rewrites

# --- Keycloak Admin ---
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=admin

# --- RabbitMQ ---
RABBITMQ_DEFAULT_USER=nexusgrid
RABBITMQ_DEFAULT_PASS=nexusgrid123

# -----------------------------------------------
# Local port-forwards (managed by skaffold dev)
# -----------------------------------------------
# Frontend:     http://localhost:3000
# API Gateway:  http://localhost:8080
# Auth Service: http://localhost:8081
# Keycloak:     http://localhost:8180
# RabbitMQ UI:  http://localhost:15672
